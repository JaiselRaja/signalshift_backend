# ─── Database ───
DATABASE_URL=postgresql+asyncpg://signal:shift@localhost:5432/signalshift
DATABASE_POOL_SIZE=20
DATABASE_ECHO=false

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───
JWT_SECRET_KEY=super-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ───
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# ─── Payment ───
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── UPI (manual verification flow) ───
UPI_VPA=
UPI_PAYEE_NAME=Signal Shift

# ─── Email (MSG91 — OTP only) ───
MSG91_AUTH_KEY=
MSG91_EMAIL_DOMAIN=msg.signalshift.in
MSG91_FROM_EMAIL=no-reply@msg.signalshift.in
MSG91_FROM_NAME=Signal Shift
MSG91_OTP_TEMPLATE_ID=

# ─── Email (SendGrid — transactional) ───
# Used for booking/payment/team/tournament emails. MSG91 stays for OTP.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@signalshift.in
SENDGRID_FROM_NAME=Signal Shift
# Optional — receives "new booking" admin alerts. Leave blank to disable.
ADMIN_NOTIFICATION_EMAIL=
# Used in email CTAs (buttons, links).
FRONTEND_BASE_URL=https://signalshift.in
BRAND_SUPPORT_EMAIL=support@signalshift.in

# ─── App ───
APP_NAME=Signal Shift API
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]
