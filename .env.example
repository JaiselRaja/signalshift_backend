# ─── Database ───
DATABASE_URL=postgresql+asyncpg://signal:shift@localhost:5432/signalshift
DATABASE_POOL_SIZE=20
DATABASE_ECHO=false

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───
JWT_SECRET_KEY=super-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── OTP ───
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# ─── Payment ───
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── UPI (manual verification flow) ───
UPI_VPA=
UPI_PAYEE_NAME=Signal Shift

# ─── Email (MSG91) ───
MSG91_AUTH_KEY=
MSG91_EMAIL_DOMAIN=msg.signalshift.in
MSG91_FROM_EMAIL=no-reply@msg.signalshift.in
MSG91_FROM_NAME=Signal Shift
MSG91_OTP_TEMPLATE_ID=

# ─── App ───
APP_NAME=Signal Shift API
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]
